\RequirePackage{etoolbox}
\RequirePackage{tikz} % loads pgfkeys
\makeatletter

% ------------------------------------------------------------
% Utilities
% ------------------------------------------------------------
\newcommand{\BTKAppendGraphicPath}[1]{%
  \@ifundefined{Ginput@path}{%
    \graphicspath{{#1}}%
  }{%
    \g@addto@macro\Ginput@path{{#1}}%
  }%
}

\newcommand{\BTKUndefIfDefined}[1]{%
  \@ifundefined{#1}{}{%
    \global\expandafter\let\csname #1\endcsname\@undefined
  }%
}

\newcommand{\BTKCoordUndefIfDefined}[1]{%
  % #1 = coordinate/node name string, e.g. BTK@box@main@nw
  \@ifundefined{pgf@sh@ns@#1}{}{%
    \global\expandafter\let\csname pgf@sh@ns@#1\endcsname\@undefined
    % optional: also clear the saved point (often enough just ns)
    \global\expandafter\let\csname pgf@sh@np@#1\endcsname\@undefined
  }%
}

\newcommand{\BTKFrameCounter}{%
  \insertframenumber/\insertmainframenumber%
}

% ------------------------------------------------------------
% Store/Retrieve API
% ------------------------------------------------------------
% Backing store: PGF keys
%   /btk/content/<name>  -> token list (content)
%   /btk/opt/<name>      -> token list (options)
%   /btk/layout/<name>      -> token list (layout)
% ------------------------------------------------------------
\pgfkeys{
  /btk/.is family,
  /btk/content/.is family,
  /btk/opt/.is family,
  /btk/layout/.is family,
  % unknown layouts -> BTK error
  /btk/layout/.unknown/.code = {%
    \PackageError{beamertoolkit}{Unknown layout `\pgfkeyscurrentname`}{%
      Define it with \string\BTKDefineLayout\space before use.%
    }%
  },
}

% Setters (store values)
\newcommand{\BTKContent}[2]{%
  % stores tokens literally; safe for paragraphs too
  \pgfkeyssetvalue{/btk/content/#1}{#2}%
}
\newcommand{\BTKOption}[2]{%
  \pgfkeyssetvalue{/btk/opt/#1}{#2}%
}

% Getters (return empty if not defined)
\newcommand{\BTKGetContent}[1]{%
  \pgfkeysifdefined{/btk/content/#1}{\pgfkeysvalueof{/btk/content/#1}}{}%
}
\newcommand{\BTKGetOption}[1]{%
  \pgfkeysifdefined{/btk/opt/#1}{\pgfkeysvalueof{/btk/opt/#1}}{}%
}
\newcommand{\BTKGetOptionOr}[2]{%
  \pgfkeysifdefined{/btk/opt/#1}{\pgfkeysvalueof{/btk/opt/#1}}{#2}%
}

% ------------------------------------------------------------
% Debug mode (optional)
% ------------------------------------------------------------
\newif\ifBTKDebug
\BTKDebugfalse

\tikzset{
  btk/outline/.style   ={draw=black,line width=0.8pt},
  btk/nooutline/.style={draw=none},
}

\newif\ifBTKOutline
\BTKOutlinefalse % set true to see borders

\newcommand{\BTKDrawOpt}{%
  \ifBTKOutline btk/outline\else btk/nooutline\fi
}

% ----------------------------
% Background registry and per-frame state
% ----------------------------
\newcommand{\BTKDeclareBackground}[2]{%
  \@namedef{BTK@bgfile@#1}{#2}%
}

% Background state
\def\BTK@mode@image{image}
\def\BTK@mode@color{color}
\def\BTK@mode@none{none}

\let\BTK@bgmode\BTK@mode@image  % init

\def\BTK@bgfile{}
\def\BTK@bgcolor{black}
\def\BTK@bgopacity{1}

\def\BTK@defaultbg{default}
\def\BTK@titlebg{title}
\def\BTK@appendixbg{appendix}

\newcommand{\BTKUseBackground}[1]{%
  \let\BTK@bgmode\BTK@mode@image%
  \edef\BTK@bgname{#1}%
  \@ifundefined{BTK@bgfile@\BTK@bgname}{%
    \PackageError{beamertoolkit}{Unknown background `\BTK@bgname`}{...}%
    \def\BTK@bgfile{}%
  }{%
    \edef\BTK@bgfile{\csname BTK@bgfile@\BTK@bgname\endcsname}%
  }%
}

\newcommand{\BTKUseBackgroundColor}[1]{%
  \let\BTK@bgmode\BTK@mode@color%
  \def\BTK@bgcolor{#1}%
}

\newcommand{\BTKNoBackground}{%
  \let\BTK@bgmode\BTK@mode@none%
  % optional, for sanity in logs:
  % \def\BTK@bgfile{}%
}

\newcommand{\BTKSetTitleBackground}[1]{\edef\BTK@titlebg{#1}}
\newcommand{\BTKSetAppendixBackground}[1]{\edef\BTK@appendixbg{#1}}\newcommand{\BTKUseBackgroundFile}[1]{%
  \def\BTK@bgmode{\BTK@mode@image}%
  \edef\BTK@bgfile{#1}%
}
\newcommand{\BTKSetBackgroundOpacity}[1]{\def\BTK@bgopacity{#1}}

\define@key{beamerframe}{bg}{\BTKUseBackground{#1}}
\define@key{beamerframe}{bgfile}{\BTKUseBackgroundFile{#1}}
\define@key{beamerframe}{bgcolor}{\BTKUseBackgroundColor{#1}}
\define@key{beamerframe}{bgopacity}{\BTKSetBackgroundOpacity{#1}}
\define@key{beamerframe}{bgnone}[true]{\BTKNoBackground}

\newcommand{\BTK@drawbackground}{%
  \ifx\BTK@bgmode\BTK@mode@none
    % nothing
  \else\ifx\BTK@bgmode\BTK@mode@color
    \fill[fill=\BTK@bgcolor,opacity=\BTK@bgopacity]
      (current page.south west) rectangle (current page.north east);%
  \else
    \node[inner sep=0pt,outer sep=0pt,opacity=\BTK@bgopacity] at (current page.center) {%
      \includegraphics[width=\paperwidth,keepaspectratio]{\BTK@bgfile}%
    };%
  \fi\fi
}

% ------------------------------------------------------------
% Layout registry (pgfkeys-backed)
% ------------------------------------------------------------


% Define a layout: stores code that will run when the key is executed
\newcommand{\BTKDefineLayout}[2]{%
  \pgfkeys{/btk/layout/#1/.code={#2}}%
}

\newcommand{\BTKUseLayout}[1]{%
  % execute; if unknown, /btk/layout/.unknown fires
  \pgfkeys{/btk/layout/#1}%
}

% ------------------------------------------------------------
% Overlay environment (power mode)
% ------------------------------------------------------------
% This is a nice helper for author code: it creates a TikZ picture with remember picture + overlay, so you can use absolute coordinates and all the anchors defined.
\newenvironment{BTKOverlay}{%
  \begin{tikzpicture}[remember picture,overlay]%
}{%
  \end{tikzpicture}%
}

% ------------------------------------------------------------
% BTK beamer templates
% ------------------------------------------------------------

% Optional per-frame toggle:
%\begin{frame}[btkoverlay=false] % <- disables btk overlay for this frame.
%  ...
%\end{frame}

\newif\ifBTKAutoOverlay
\BTKAutoOverlaytrue
\define@key{beamerframe}{btkoverlay}[true]{\csname BTKAutoOverlay#1\endcsname}

% Set the background template to draw the current background (which may be set per frame or by theme)
\newcommand{\BTKInstallTemplates}{%
  \setbeamertemplate{background}{
    \begin{BTKOverlay}%
      \BTK@drawbackground%
    \end{BTKOverlay}%
  }

  % Theme-defined template; default empty
  \setbeamertemplate{btk overlay}{}

  % Wrapper that executes the template inside a single overlay tikzpicture
  \newcommand{\BTKRenderOverlay}{%
    \ifBTKAutoOverlay
      \begin{BTKOverlay}%
        \usebeamertemplate{btk overlay}%
      \end{BTKOverlay}%
    \fi
  }

  % Critical: run BEFORE \end{frame} finishes (still within the frame build)
  \AtEndEnvironment{frame}{
    \BTKRenderOverlay
  }
}

% ------------------------------------------------------------
% Beamer frame keys (bridge)
% ------------------------------------------------------------
% layout=<name> runs the layout code (template changes remain local to this frame)
\define@key{beamerframe}{layout}{\BTKUseLayout{#1}}

% btk={k=v,...} parses a PGF keylist into /btk/opt/<k>=<v>
\define@key{beamerframe}{btk}{\pgfkeys{/btk/opt/.cd,#1}}

\makeatother
