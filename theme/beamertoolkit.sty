% ------------------------------------------------------------
% Utilities
% ------------------------------------------------------------
\newcommand{\BTKAppendGraphicPath}[1]{%
  \@ifundefined{Ginput@path}{%
    \graphicspath{{#1}}%
  }{%
    \g@addto@macro\Ginput@path{{#1}}%
  }%
}

\newcommand{\BTKUndefIfDefined}[1]{%
  \@ifundefined{#1}{}{%
    \global\expandafter\let\csname #1\endcsname\@undefined
  }%
}

\newcommand{\BTKCoordUndefIfDefined}[1]{%
  % #1 = coordinate/node name string, e.g. BTK@box@main@nw
  \@ifundefined{pgf@sh@ns@#1}{}{%
    \global\expandafter\let\csname pgf@sh@ns@#1\endcsname\@undefined
    % optional: also clear the saved point (often enough just ns)
    \global\expandafter\let\csname pgf@sh@np@#1\endcsname\@undefined
  }%
}

% ------------------------------------------------------------
% PGF Store/Retrieve API
% ------------------------------------------------------------
% Backing store: PGF keys
%   /btk/content/<name>  -> token list (content)
%   /btk/opt/<name>      -> token list (options)
%   /btk/layout/<name>      -> token list (layout)
% ------------------------------------------------------------
\pgfkeys{
  /btk/.is family,
  /btk/opt/.is family,
  % unknown layouts -> BTK error
  /btk/content/.is family,
  /btk/content/.unknown/.code = {%
    \PackageError{beamertoolkit}{Unknown content `\pgfkeyscurrentname`}{%
      Define it with \string\BTKContent\space before use.%
    }%
  },
  /btk/layout/.is family,
  % unknown layouts -> BTK error
  /btk/layout/.unknown/.code = {%
    \PackageError{beamertoolkit}{Unknown layout `\pgfkeyscurrentname`}{%
      Define it with \string\BTKDefineLayout\space before use.%
    }%
  },
}

% Setters (store values)
\NewDocumentCommand{\BTKContent}{m +m}{%
  % define a real key with code
  \begingroup\globaldefs=1
    \pgfkeys{/btk/content/#1/.code={#2}}%
  \endgroup
}
\newcommand{\BTKOption}[2]{%
  \pgfkeyssetvalue{/btk/opt/#1}{#2}%
}

% Getters (return empty if not defined)
\newcommand{\BTKGetContent}[1]{%
  % execute; if unknown, /btk/content/.unknown fires
  \pgfkeys{/btk/content/#1}%
}
\newcommand{\BTKGetOption}[1]{%
  \pgfkeysifdefined{/btk/opt/#1}{\pgfkeysvalueof{/btk/opt/#1}}{}%
}
\newcommand{\BTKGetOptionOr}[2]{%
  \pgfkeysifdefined{/btk/opt/#1}{\pgfkeysvalueof{/btk/opt/#1}}{#2}%
}

\newcommand{\BTKDbgContent}[1]{%
  \pgfkeysgetvalue{/btk/content/#1}{\BTK@tmp}%
  \ifx\BTK@tmp\pgfkeysnovalue
    \typeout{BTK content/#1 UNDEFINED}%
  \else
    \typeout{BTK content/#1 defined (length unknown)}%
  \fi
}

% ------------------------------------------------------------
% Padding Helpers
% ------------------------------------------------------------

% Defaults used by BTKRectMP
\newlength\BTKBoxPadX
\newlength\BTKBoxPadY
\newdimen\BTK@tmpW
\newdimen\BTK@tmpH

% Set padding based on a beamer font (e.g. normal text, frametitle, footline)
\newcommand{\BTKSetBoxPaddingFromBeamerFont}[1]{%
  \usebeamerfont{#1}%
  % measure 1em in the currently selected font:
  \setbox0=\hbox{\hspace{0.8em}}%
  \setlength{\BTKBoxPadX}{\wd0}%
  %\global\BTKBoxPadX=\wd0\relax
  % vertical padding as ~1/2 baseline skip:
  \setlength{\BTKBoxPadY}{\dimexpr\baselineskip/2\relax}%
  %\global\BTKBoxPadY=\dimexpr\baselineskip/2\relax
  %\global\BTKBoxPadY=\dimexpr\baselineskip/3\relax
  %\global\BTKBoxPadY=\dimexpr 2\baselineskip/3\relax
}

% ------------------------------------------------------------
% Draw Helpers
% ------------------------------------------------------------
% \BTKRectMP*[<tikz node opts>][<mp pos>][<mp inner-pos>]{<NW>}{<SE>}{<content>}
% - <NW>, <SE> are coordinates (names or full calc expressions)
% - node is placed at NW, sized by (SE.x-NW.x) and (NW.y-SE.y)
% Star (*) disables clipping to the rectangle.
% Warning, don't put ';' after these calls.
% Default: clip. Star (*) disables clipping.
% \BTKRectMP*[<node opts>][<mp pos>][<mp inner-pos>][<xpad>][<ypad>]{NW}{SE}{content}
\NewDocumentCommand{\BTKRectMP}{ s O{} O{c} O{c} O{\BTKBoxPadX} O{\BTKBoxPadY} m m +m }{%
  \begin{scope}%
    \coordinate (BTK@nw) at (#7);%
    \coordinate (BTK@se) at (#8);%

    \IfBooleanF{#1}{\clip (BTK@nw) rectangle (BTK@se);}%

    \path let \p1=(BTK@nw), \p2=(BTK@se) in
      \pgfextra{%
        \global\BTK@tmpW=\dimexpr\x2-\x1-2\dimexpr#5\relax\relax
        \global\BTK@tmpH=\dimexpr\y1-\y2-2\dimexpr#6\relax\relax
      };%

    \ifBTKOutline
      \path[btk/outline-outer] (BTK@nw) rectangle (BTK@se);%
      \path[btk/outline-inner] ($(BTK@nw)+(#5,-#6)$) rectangle ($(BTK@se)+(-#5,#6)$);%
    \fi

    % DEBUG: show node-opts argument so you can catch mis-parsing
    %\typeout{BTKRectMP node-opts=[#2] mp=[#3][#4]}%

    \node[
      anchor=north west,
      inner sep=0pt, outer sep=0pt,
      fill=none,
      #2%
    ] at ($(BTK@nw)+(#5,-#6)$) {%
      \begin{minipage}[#3][\BTK@tmpH][#4]{\BTK@tmpW}%
        #9%
      \end{minipage}%
    };%
  \end{scope}%
}

