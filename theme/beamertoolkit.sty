% theme/beamertoolkit.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamertoolkit}[2026/02/12 BTK: rects + slots + layouts]

\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{tikz}
\usetikzlibrary{calc}

\makeatletter

% ------------------------------------------------------------
% Utilities
% ------------------------------------------------------------
\newcommand{\BTKAppendGraphicPath}[1]{%
  \@ifundefined{Ginput@path}{%
    \graphicspath{{#1}}%
  }{%
    \g@addto@macro\Ginput@path{{#1}}%
  }%
}

% ------------------------------------------------------------
% Anchors
% ------------------------------------------------------------
\newcommand{\BTKPageAnchor}[1]{BTK@page@#1}           % nw ne sw se c
\newcommand{\BTKRectAnchor}[2]{BTK@rect@#1@#2}        % rect name, nw/ne/sw/se/c

% ------------------------------------------------------------
% Debug mode (optional)
% ------------------------------------------------------------
\newif\ifBTKDebug
\BTKDebugfalse

% Default debug style
\def\BTKDebugLWDefault{0.8pt}
\def\BTKDebugColorDefault{black}

% Per-rect debug style setters
\newcommand{\BTKSetRectDebugStyle}[3]{%
  \@namedef{BTK@dbgcol@#1}{#2}%
  \@namedef{BTK@dbglw@#1}{#3}%
}

% Some nice defaults for common names (theme can override via BTKSetRectDebugStyle)
\BTKSetRectDebugStyle{page}{black}{0.9pt}
\BTKSetRectDebugStyle{header}{blue!70!black}{0.8pt}
\BTKSetRectDebugStyle{footer}{red!70!black}{0.8pt}
\BTKSetRectDebugStyle{body}{black!70}{0.8pt}
\BTKSetRectDebugStyle{main}{black}{0.8pt}
\BTKSetRectDebugStyle{left}{teal!70!black}{0.8pt}
\BTKSetRectDebugStyle{right}{violet!70!black}{0.8pt}
\BTKSetRectDebugStyle{text}{green!60!black}{0.8pt}
\BTKSetRectDebugStyle{img}{orange!80!black}{0.8pt}
\BTKSetRectDebugStyle{title}{blue!70!black}{0.8pt}
\BTKSetRectDebugStyle{author}{black!70}{0.8pt}
\BTKSetRectDebugStyle{date}{black!70}{0.8pt}
\BTKSetRectDebugStyle{footer-left}{red!70!black}{0.7pt}
\BTKSetRectDebugStyle{footer-center}{red!70!black}{0.7pt}
\BTKSetRectDebugStyle{footer-right}{red!70!black}{0.7pt}

\newcommand{\BTK@dbgstylefor}[1]{%
  \def\BTK@dbgcol{\BTKDebugColorDefault}%
  \def\BTK@dbglw{\BTKDebugLWDefault}%
  \@ifundefined{BTK@dbgcol@#1}{}{%
    \edef\BTK@dbgcol{\csname BTK@dbgcol@#1\endcsname}%
  }%
  \@ifundefined{BTK@dbglw@#1}{}{%
    \edef\BTK@dbglw{\csname BTK@dbglw@#1\endcsname}%
  }%
}

% ------------------------------------------------------------
% Rect registry (per frame)
% ------------------------------------------------------------
\def\BTK@rectlist{} % comma-separated rect names for this frame

\newcommand{\BTK@rectsReset}{%
  \global\let\BTK@rectlist\@empty
}

\newcommand{\BTK@rectadd}[1]{%
  \ifx\BTK@rectlist\@empty
    \xdef\BTK@rectlist{#1}%
  \else
    \xdef\BTK@rectlist{\BTK@rectlist,#1}%
  \fi
}

% Define a rectangle by NW and SE coords.
% Must be called inside a tikzpicture.
\newcommand{\BTKDeclareRect}[3]{%
  \BTK@rectadd{#1}%
  \coordinate (\BTKRectAnchor{#1}{nw}) at #2;%
  \coordinate (\BTKRectAnchor{#1}{se}) at #3;%
  \coordinate (\BTKRectAnchor{#1}{ne}) at (\BTKRectAnchor{#1}{nw}) -| (\BTKRectAnchor{#1}{se});%
  \coordinate (\BTKRectAnchor{#1}{sw}) at (\BTKRectAnchor{#1}{nw}) |- (\BTKRectAnchor{#1}{se});%
  \coordinate (\BTKRectAnchor{#1}{c})  at ($(\BTKRectAnchor{#1}{nw})!0.5!(\BTKRectAnchor{#1}{se})$);%
}

% ------------------------------------------------------------
% Layout registry + per-frame key
% ------------------------------------------------------------
\newcommand{\BTKDeclareLayout}[2]{%
  \@namedef{BTK@layout@#1}{#2}%
}

\def\BTK@layout{full}
\def\BTK@defaultlayout{full}

\newcommand{\BTKSetDefaultLayout}[1]{%
  \def\BTK@defaultlayout{#1}%
  \def\BTK@layout{#1}%
}

\define@key{beamerframe}{layout}{\def\BTK@layout{#1}}

\newcommand{\BTKApplyLayout}{%
  \@ifundefined{BTK@layout@\BTK@layout}{%
    \PackageError{beamertoolkit}{Unknown layout `\BTK@layout`}%
      {Declare it with \string\BTKDeclareLayout\space (theme or preamble).}%
  }{%
    \csname BTK@layout@\BTK@layout\endcsname
  }%
}

% ------------------------------------------------------------
% Slots (defaults + per-frame overrides)
% ------------------------------------------------------------
\def\BTK@slotlist{} % comma-separated slot names

\newcommand{\BTK@slotadd}[1]{%
  \ifx\BTK@slotlist\@empty
    \xdef\BTK@slotlist{#1}%
  \else
    \xdef\BTK@slotlist{\BTK@slotlist,#1}%
  \fi
}

\newcommand{\BTKDeclareSlot}[2]{%
  \BTK@slotadd{#1}%
  \@namedef{BTK@slot@default@#1}{#2}%
  % If current slot not defined yet, initialize it (useful outside frames too)
  \@ifundefined{BTK@slot@#1}{\@namedef{BTK@slot@#1}{#2}}{}%
}

\newcommand{\BTKSetSlotDefault}[2]{%
  \@namedef{BTK@slot@default@#1}{#2}%
}

\newcommand{\BTKResetSlotsToDefaults}{%
  \forcsvlist\BTK@slotreset{\BTK@slotlist}%
}
\newcommand{\BTK@slotreset}[1]{%
  \@ifundefined{BTK@slot@default@#1}{%
    \@namedef{BTK@slot@#1}{}%
  }{%
    \expandafter\gdef\csname BTK@slot@#1\endcsname{\csname BTK@slot@default@#1\endcsname}%
  }%
}

\newcommand{\BTKSetSlot}[2]{%
  \expandafter\gdef\csname BTK@slot@#1\endcsname{#2}%
}

\newcommand{\BTKUseSlot}[1]{%
  \@ifundefined{BTK@slot@#1}{}{%
    \csname BTK@slot@#1\endcsname
  }%
}

\newcommand{\BTKIfSlotEmpty}[3]{%
  \edef\BTK@tmp{\BTKUseSlot{#1}}%
  \ifx\BTK@tmp\@empty #2\else #3\fi
}

% ------------------------------------------------------------
% Main slide total (exclude appendix/backup): BTKAppendixBegin writes total to aux
% ------------------------------------------------------------
\providecommand{\BTKMainTotal}{} % empty until written/read from .aux
\newif\ifBTK@wroteMainTotal
\BTK@wroteMainTotalfalse

% Robust aux writer: do NOT expand \BTKMainTotal during \write
\newcommand{\BTK@writeMainTotalToAux}[1]{%
  % #1 should be a pure number token list (e.g. 23)
  \protected@write\@auxout{}{%
    \string\gdef\string\BTKMainTotal{#1}%
  }%
  \global\BTK@wroteMainTotaltrue
}

\newcommand{\BTKAppendixBegin}{%
  \ifBTK@wroteMainTotal\else
    \begingroup
      \edef\BTK@tmp{\number\value{framenumber}}%
      \BTK@writeMainTotalToAux{\BTK@tmp}%
    \endgroup
  \fi
  \appendix
}

% If no appendix call happened, make main total == final total (next run)
\AtEndDocument{%
  \ifBTK@wroteMainTotal\else
    \begingroup
      \edef\BTK@tmp{\number\value{framenumber}}%
      \BTK@writeMainTotalToAux{\BTK@tmp}%
    \endgroup
  \fi
}

% Use main total if available; else fall back to total
\providecommand{\insertmainframenumber}{%
  \ifx\BTKMainTotal\@empty
    \inserttotalframenumber
  \else
    \BTKMainTotal
  \fi
}

% ----------------------------
% Background registry
% ----------------------------
\newcommand{\BTKDeclareBackground}[2]{%
  \@namedef{BTK@bgfile@#1}{#2}%
}

% Background state
\def\BTK@mode@image{image}
\def\BTK@mode@color{color}
\def\BTK@mode@none{none}

\def\BTK@bgmode{image}
\def\BTK@bgfile{}
\def\BTK@bgcolor{black}
\def\BTK@bgopacity{1}

\def\BTK@defaultbg{default}
\def\BTK@titlebg{title}
\def\BTK@appendixbg{appendix}

\newcommand{\BTKUseBackground}[1]{%
  \def\BTK@bgmode{\BTK@mode@image}%
  \edef\BTK@bgname{#1}%
  \@ifundefined{BTK@bgfile@\BTK@bgname}{%
    \PackageError{beamertoolkit}{Unknown background `\BTK@bgname`}%
      {Declare it with \string\BTKDeclareBackground\space before use.}%
    \def\BTK@bgfile{}%
  }{%
    \edef\BTK@bgfile{\csname BTK@bgfile@\BTK@bgname\endcsname}%
  }%
}

\newcommand{\BTKSetDefaultBackground}[1]{%
  \edef\BTK@defaultbg{#1}%
  \BTKUseBackground{#1}%
}
\newcommand{\BTKSetTitleBackground}[1]{\edef\BTK@titlebg{#1}}
\newcommand{\BTKSetAppendixBackground}[1]{\edef\BTK@appendixbg{#1}}\newcommand{\BTKUseBackgroundFile}[1]{%
  \def\BTK@bgmode{\BTK@mode@image}%
  \edef\BTK@bgfile{#1}%
}
\newcommand{\BTKUseBackgroundColor}[1]{%
  \def\BTK@bgmode{\BTK@mode@color}%
  \def\BTK@bgcolor{#1}%
}
\newcommand{\BTKNoBackground}{\def\BTK@bgmode{\BTK@mode@none}}
\newcommand{\BTKSetBackgroundOpacity}[1]{\def\BTK@bgopacity{#1}}

\define@key{beamerframe}{bg}{\BTKUseBackground{#1}}
\define@key{beamerframe}{bgfile}{\BTKUseBackgroundFile{#1}}
\define@key{beamerframe}{bgcolor}{\BTKUseBackgroundColor{#1}}
\define@key{beamerframe}{bgopacity}{\BTKSetBackgroundOpacity{#1}}
\define@key{beamerframe}{bgnone}[true]{\BTKNoBackground}

% ------------------------------------------------------------
% Per-frame init/reset
% ------------------------------------------------------------
\newif\ifBTK@inited
\BTK@initedfalse

\newcommand{\BTKFrameReset}{%
  \global\BTK@initedfalse
  \BTKResetSlotsToDefaults
  % reset layout + background to theme defaults for the next frame
  \def\BTK@layout{\BTK@defaultlayout}%
  \BTKUseBackground{\BTK@defaultbg}%
  % bg opacity should not stick by default
  \BTKSetBackgroundOpacity{1}%
}

\AtBeginEnvironment{frame}{\BTKFrameReset}
\AfterEndEnvironment{frame}{\BTKFrameReset}


% ------------------------------------------------------------
% Init inside TikZ overlay: define page anchors + apply layout once
% ------------------------------------------------------------
\newcommand{\BTKInitInTikZ}{%
  \ifBTK@inited\else
    \BTK@rectsReset%
    % page anchors
    \coordinate (\BTKPageAnchor{nw}) at (current page.north west);%
    \coordinate (\BTKPageAnchor{ne}) at (current page.north east);%
    \coordinate (\BTKPageAnchor{sw}) at (current page.south west);%
    \coordinate (\BTKPageAnchor{se}) at (current page.south east);%
    \coordinate (\BTKPageAnchor{c})  at (current page.center);%
    % apply layout (theme defines rects)
    \usebeamertemplate{BTK/layout}%
    \global\BTK@initedtrue
  \fi
}

% ------------------------------------------------------------
% Overlay environment (power mode)
% ------------------------------------------------------------
\newenvironment{BTKOverlay}{%
  \begin{tikzpicture}[remember picture,overlay]%
    \BTKInitInTikZ%
}{%
  \end{tikzpicture}%
}

% ------------------------------------------------------------
% Box placement helpers (rect -> minipage)
% ------------------------------------------------------------
\newdimen\BTK@rectW
\newdimen\BTK@rectH

\newcommand{\BTK@calcRectWH}[1]{%
  \path let \p1=(\BTKRectAnchor{#1}{nw}), \p2=(\BTKRectAnchor{#1}{se}) in
    \pgfextra{%
      \global\BTK@rectW=\dimexpr\x2-\x1\relax
      \global\BTK@rectH=\dimexpr\y1-\y2\relax
    };%
}

% Place arbitrary content into a rect (call inside BTKOverlay or any tikz overlay)
% Optional arg: TikZ node options (xshift=..., yshift=..., inner sep=..., etc.)
\newcommand{\BTKPlaceRect}[3][]{%
  \BTK@calcRectWH{#2}%
  \node[anchor=north west,inner sep=0pt,outer sep=0pt,#1]%
    at (\BTKRectAnchor{#2}{nw}) {%
      \begin{minipage}[t][\BTK@rectH][t]{\BTK@rectW}%
        \ignorespaces#3\unskip
      \end{minipage}%
    };%
}

% Place a slot into a rect
\newcommand{\BTKPlaceSlot}[3][]{%
  \BTKPlaceRect[#1]{#2}{\BTKUseSlot{#3}}%
}

% Author-facing region environment (drop normal TeX into a named rect)
\newsavebox{\BTK@regionbox}
\newcommand{\BTK@regionname}{}
\newcommand{\BTK@regionopts}{}

\newenvironment{BTKRegion}[2][]{%
  \def\BTK@regionopts{#1}%
  \def\BTK@regionname{#2}%
  % ensure rect exists for this layout (needs overlay context)
  \begin{BTKOverlay}%
    \@ifundefined{pgf@sh@ns@\BTKRectAnchor{#2}{nw}}{%
      \PackageError{beamertoolkit}{Rect `#2' is not defined for layout `\BTK@layout'}%
        {Define it in the layout via \string\BTKDeclareRect.}%
    }{}%
    \BTK@calcRectWH{#2}%
  \end{BTKOverlay}%
  \begin{lrbox}{\BTK@regionbox}%
    \begin{minipage}[t][\BTK@rectH][t]{\BTK@rectW}%
      \ignorespaces%
}{%
    \end{minipage}%
  \end{lrbox}%
  \begin{BTKOverlay}%
    \BTKPlaceRect[\BTK@regionopts]{\BTK@regionname}{\usebox{\BTK@regionbox}}%
    \ifBTKDebug%
      \BTK@dbgstylefor{\BTK@regionname}%
      \draw[draw=\BTK@dbgcol,line width=\BTK@dbglw]%
        (\BTKRectAnchor{\BTK@regionname}{sw}) rectangle (\BTKRectAnchor{\BTK@regionname}{ne});%
    \fi%
  \end{BTKOverlay}%
}

% ------------------------------------------------------------
% Even-spacing helpers (inside boxes/slots)
% ------------------------------------------------------------
\newif\ifBTK@firsthitem
\newenvironment{BTKHList}[1][\linewidth]{%
  \BTK@firsthitemtrue%
  \hbox to #1\bgroup\ignorespaces%
}{%
  \egroup%
}
\newcommand{\BTKHItem}[1]{%
  \ifBTK@firsthitem\BTK@firsthitemfalse\else\hfil\fi%
  \strut #1%
}

\newif\ifBTK@firstvitem
\newenvironment{BTKVList}[1]{%
  \BTK@firstvitemtrue%
  \vbox to #1\bgroup\ignorespaces%
}{%
  \egroup%
}
\newcommand{\BTKVItem}[1]{%
  \ifBTK@firstvitem\BTK@firstvitemfalse\else\vfil\fi%
  \hbox{#1}%
}

% ------------------------------------------------------------
% BTK beamer templates
% ------------------------------------------------------------
\defbeamertemplate*{BTK/layout}{default}{%
  \BTKApplyLayout%
}

\defbeamertemplate*{BTK/background}{default}{%
  \ifx\BTK@bgmode\BTK@mode@none
    % nothing
  \else\ifx\BTK@bgmode\BTK@mode@color
    \fill[fill=\BTK@bgcolor,opacity=\BTK@bgopacity]
      (current page.south west) rectangle (current page.north east);%
  \else
    \node[inner sep=0pt,outer sep=0pt,opacity=\BTK@bgopacity] at (current page.center) {%
      \includegraphics[width=\paperwidth,keepaspectratio]{\BTK@bgfile}%
    };%
  \fi\fi
}

\defbeamertemplate*{BTK/foreground}{default}{%
  % theme may override
}

% Debug draw of all rects registered this frame
\newcommand{\BTKDebugDraw}{%
  \ifBTKDebug%
    \forcsvlist\BTK@dbgdrawrect{\BTK@rectlist}%
  \fi%
}
\newcommand{\BTK@dbgdrawrect}[1]{%
  \@ifundefined{pgf@sh@ns@\BTKRectAnchor{#1}{nw}}{}{%
    \BTK@dbgstylefor{#1}%
    \draw[draw=\BTK@dbgcol,line width=\BTK@dbglw]%
      (\BTKRectAnchor{#1}{sw}) rectangle (\BTKRectAnchor{#1}{ne});%
  }%
}

% One reliable per-frame hook: Beamer background runs every slide.
% This is *init + (optional) background + debug + foreground*.
\setbeamertemplate{background}{%
  \begin{BTKOverlay}%
    \usebeamertemplate{BTK/background}%
    \BTKDebugDraw%
    \usebeamertemplate{BTK/foreground}%
  \end{BTKOverlay}%
}

\makeatother
