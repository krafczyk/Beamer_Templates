% ------------------------------------------------------------
% Utilities
% ------------------------------------------------------------
\newcommand{\BTKAppendGraphicPath}[1]{%
  \@ifundefined{Ginput@path}{%
    \graphicspath{{#1}}%
  }{%
    \g@addto@macro\Ginput@path{{#1}}%
  }%
}

\newcommand{\BTKUndefIfDefined}[1]{%
  \@ifundefined{#1}{}{%
    \expandafter\let\csname #1\endcsname\@undefined
  }%
}

\newcommand{\BTKCoordUndefIfDefined}[1]{%
  % #1 = coordinate/node name string, e.g. BTK@box@main@nw
  \@ifundefined{pgf@sh@ns@#1}{}{%
    \global\expandafter\let\csname pgf@sh@ns@#1\endcsname\@undefined
    % optional: also clear the saved point (often enough just ns)
    \global\expandafter\let\csname pgf@sh@np@#1\endcsname\@undefined
  }%
}

\newcommand{\BTKFrameCounter}{%
  \insertframenumber/\insertmainframenumber%
}

% ------------------------------------------------------------
% Debug mode (optional)
% ------------------------------------------------------------
\newif\ifBTKDebug
\BTKDebugfalse

% Default debug style
\def\BTKDebugLWDefault{0.8pt}
\def\BTKDebugColorDefault{black}

% Per-box debug style setters
\newcommand{\BTKSetBoxDebugStyle}[3]{%
  \@namedef{BTK@box@#1@dbgcol}{#2}%
  \@namedef{BTK@box@#1@dbglw}{#3}%
}

% Some nice defaults for common names (theme can override via BTKSetRectDebugStyle)
\BTKSetBoxDebugStyle{page}{black}{0.9pt}
\BTKSetBoxDebugStyle{header}{blue!70!black}{0.8pt}
\BTKSetBoxDebugStyle{footer}{red!70!black}{0.8pt}
\BTKSetBoxDebugStyle{body}{black!70}{0.8pt}
\BTKSetBoxDebugStyle{main}{black}{0.8pt}
\BTKSetBoxDebugStyle{left}{teal!70!black}{0.8pt}
\BTKSetBoxDebugStyle{right}{violet!70!black}{0.8pt}
\BTKSetBoxDebugStyle{text}{green!60!black}{0.8pt}
\BTKSetBoxDebugStyle{img}{orange!80!black}{0.8pt}
\BTKSetBoxDebugStyle{title}{blue!70!black}{0.8pt}
\BTKSetBoxDebugStyle{author}{black!70}{0.8pt}
\BTKSetBoxDebugStyle{date}{black!70}{0.8pt}
\BTKSetBoxDebugStyle{footer-left}{red!70!black}{0.7pt}
\BTKSetBoxDebugStyle{footer-center}{red!70!black}{0.7pt}
\BTKSetBoxDebugStyle{footer-right}{red!70!black}{0.7pt}

\newcommand{\BTK@dbgstylefor}[1]{%
  \def\BTK@dbgcol{\BTKDebugColorDefault}%
  \def\BTK@dbglw{\BTKDebugLWDefault}%
  \@ifundefined{BTK@box@#1@dbgcol}{}{%
    \edef\BTK@dbgcol{\csname BTK@box@#1@dbgcol\endcsname}%
  }%
  \@ifundefined{BTK@box@#1@dbglw}{}{%
    \edef\BTK@dbglw{\csname BTK@box@#1@dbglw\endcsname}%
  }%
}

% ------------------------------------------------------------
% Box registry (per frame)
% ------------------------------------------------------------
% etoolbox list storage (starts empty)
\let\BTK@boxlist\@empty

\newcommand{\BTK@boxlistclear}{%
  \global\let\BTK@boxlist\@empty
}

% add unique (global)
\newcommand{\BTK@boxadd}[1]{%
  \ifinlist{#1}{\BTK@boxlist}{%
    \PackageError{beamertoolkit}{Box `#1` is already defined for this frame}{}%
  }{%
    \listgadd\BTK@boxlist{#1}%
  }%
}

% assert membership
\newcommand{\BTK@boxassert}[1]{%
  \ifinlist{#1}{\BTK@boxlist}{}{%
    \PackageError{beamertoolkit}{Unknown box `#1`}{%
      Box `#1` is not registered for this frame.\MessageBreak
      Known boxes: \BTK@boxlist%
    }%
  }%
}

% Method to get the properties of a box.
\newcommand{\BTKBoxProp}[2]{BTK@box@#1@#2} % box name, property

% Current box group
\let\BTK@curgroup\@empty
\newcommand{\BTKSetCurrentBoxGroup}[1]{\gdef\BTK@curgroup{#1}}

% Define a rectangle by NW and SE coords.
% Must be called inside a tikzpicture.
% Just creates coordinates; does not draw anything.
\newcommand{\BTKDeclareBox}[3]{%  % box name, NW coord, SE coord
  \BTK@boxadd{#1}%
  \ifx\BTK@curgroup\@empty
    \PackageError{beamertoolkit}{Cannot declare box `#1` without a current group}%
      {Call \string\BTKSetCurrentBoxGroup\space before \string\BTKDeclareBox}%
  \else
    \@namedef{BTK@box@#1@group}{\BTK@curgroup}%
  \fi
  \coordinate (\BTKBoxProp{#1}{nw}) at #2;%
  \coordinate (\BTKBoxProp{#1}{se}) at #3;%
  \coordinate (\BTKBoxProp{#1}{ne}) at (\BTKBoxProp{#1}{nw}) -| (\BTKBoxProp{#1}{se});%
  \coordinate (\BTKBoxProp{#1}{sw}) at (\BTKBoxProp{#1}{nw}) |- (\BTKBoxProp{#1}{se});%
  \coordinate (\BTKBoxProp{#1}{c})  at ($(\BTKBoxProp{#1}{nw})!0.5!(\BTKBoxProp{#1}{se})$);%
  \coordinate (\BTKBoxProp{#1}{n})  at ($(\BTKBoxProp{#1}{nw})!0.5!(\BTKBoxProp{#1}{ne})$);%
  \coordinate (\BTKBoxProp{#1}{s})  at ($(\BTKBoxProp{#1}{sw})!0.5!(\BTKBoxProp{#1}{se})$);%
  \coordinate (\BTKBoxProp{#1}{e})  at ($(\BTKBoxProp{#1}{ne})!0.5!(\BTKBoxProp{#1}{se})$);%
  \coordinate (\BTKBoxProp{#1}{w})  at ($(\BTKBoxProp{#1}{nw})!0.5!(\BTKBoxProp{#1}{sw})$);%
}

% Set the content of the box
\newcommand{\BTKBox}[2]{%
  \BTK@boxassert{#1}%
  \@namedef{\BTKBoxProp{#1}{content}}{#2}%
}

% Remove variables associated with a box
\newcommand{\BTK@boxremove}[1]{%
  \BTKUndefIfDefined{BTK@box@#1@content}%
  \BTKUndefIfDefined{BTK@box@#1@dbgcol}%
  \BTKUndefIfDefined{BTK@box@#1@dbglw}%
  \BTKUndefIfDefined{BTK@box@#1@group}%
}

% Helper methods to find a box's height and width for use in a minipage. Call inside tikzpicture.
\newcommand{\BTK@boxwidth}[1]{%
  \dimexpr\x(\BTKBoxProp{#1}{se})-\x(\BTKBoxProp{#1}{nw})\relax
}
\newcommand{\BTK@boxheight}[1]{%
  \dimexpr\y(\BTKBoxProp{#1}{nw})-\y(\BTKBoxProp{#1}{se})\relax
}

% \BTKFilterBoxListByGroup{<in list>}{<group>}{<out macro>}
%   <in list> is an etoolbox list like: title|author|date|
%   <out macro> will be set to an etoolbox list too.
\newcommand{\BTKFilterBoxListByGroup}[3]{%
  \begingroup
    \def\BTK@want{#2}%
    \let\BTK@out\@empty
    \def\BTK@one##1{%
      \@ifundefined{BTK@box@##1@group}{}{%
        \edef\BTK@grp{\csname BTK@box@##1@group\endcsname}%
        \ifdefstring{\BTK@grp}{\BTK@want}{%
          \listgadd\BTK@out{##1}%
        }{}%
      }%
    }%
    \forlistloop{\BTK@one}{#1}%
    \xdef\BTK@result{\BTK@out}%
  \endgroup
  \expandafter\def\expandafter#3\expandafter{\BTK@result}%
}

\newcommand{\BTKBoxesInGroup}[2]{%
  \BTKFilterBoxListByGroup{\BTK@boxlist}{#1}{#2}%
}

% Draw the box content (call inside BTKOverlay or any tikz overlay)
\newcommand{\BTK@drawbox}[1]{%
  \BTK@boxassert{#1}%
  \ifundefined{BTK@box@#1@content}{%
    \PackageError{beamertoolkit}{Box `#1` has no content}{}%
  }{%
    % place content in a minipage of the right size using the NW and SE anchors
    \node [anchor=north west,inner sep=0pt,outer sep=0pt] at (\BTKBoxProp{#1}{nw}) {%
      \begin{minipage}[t][\BTK@boxheight{#1}][t]{\BTK@boxwidth{#1}}%
      \ignorespaces\csname BTK@box@#1@content\endcsname\unskip
      \end{minipage}%
    };%
    % draw debug box if debug mode is on
    \ifBTKDebug%
      \BTK@dbgstylefor{#1}%
      \draw[draw=\BTK@dbgcol,line width=\BTK@dbglw]%
      (\BTKBoxProp{#1}{sw}) rectangle (\BTKBoxProp{#1}{ne});%
  }%
}

% Public: draw all boxes in a group (call inside a tikzpicture/BTKOverlay)
\newcommand{\BTKDrawBoxesInGroup}[1]{%
  \BTKBoxesInGroup{#1}{\BTK@boxlistingroup}%
  \forlistloop{\BTK@drawbox}{\BTK@boxlistingroup}%
}

% Clear all boxes for this frame
\newcommand{\BTK@boxclear}{%
  \forlistloop{\BTK@boxremove}{\BTK@boxlist}%
  \BTK@boxlistclear
}

% ----------------------------
% Background registry and per-frame state
% ----------------------------
\newcommand{\BTKDeclareBackground}[2]{%
  \@namedef{BTK@bgfile@#1}{#2}%
}

% Background state
\def\BTK@mode@image{image}
\def\BTK@mode@color{color}
\def\BTK@mode@none{none}

\def\BTK@bgmode{image}
\def\BTK@bgfile{}
\def\BTK@bgcolor{black}
\def\BTK@bgopacity{1}

\def\BTK@defaultbg{default}
\def\BTK@titlebg{title}
\def\BTK@appendixbg{appendix}

\newcommand{\BTKUseBackground}[1]{%
  \def\BTK@bgmode{\BTK@mode@image}%
  \edef\BTK@bgname{#1}%
  \@ifundefined{BTK@bgfile@\BTK@bgname}{%
    \PackageError{beamertoolkit}{Unknown background `\BTK@bgname`}%
      {Declare it with \string\BTKDeclareBackground\space before use.}%
    \def\BTK@bgfile{}%
  }{%
    \edef\BTK@bgfile{\csname BTK@bgfile@\BTK@bgname\endcsname}%
  }%
}

\newcommand{\BTKSetDefaultBackground}[1]{%
  \edef\BTK@defaultbg{#1}%
  \BTKUseBackground{#1}%
}
\newcommand{\BTKSetTitleBackground}[1]{\edef\BTK@titlebg{#1}}
\newcommand{\BTKSetAppendixBackground}[1]{\edef\BTK@appendixbg{#1}}\newcommand{\BTKUseBackgroundFile}[1]{%
  \def\BTK@bgmode{\BTK@mode@image}%
  \edef\BTK@bgfile{#1}%
}
\newcommand{\BTKUseBackgroundColor}[1]{%
  \def\BTK@bgmode{\BTK@mode@color}%
  \def\BTK@bgcolor{#1}%
}
\newcommand{\BTKNoBackground}{\def\BTK@bgmode{\BTK@mode@none}}
\newcommand{\BTKSetBackgroundOpacity}[1]{\def\BTK@bgopacity{#1}}

\define@key{beamerframe}{bg}{\BTKUseBackground{#1}}
\define@key{beamerframe}{bgfile}{\BTKUseBackgroundFile{#1}}
\define@key{beamerframe}{bgcolor}{\BTKUseBackgroundColor{#1}}
\define@key{beamerframe}{bgopacity}{\BTKSetBackgroundOpacity{#1}}
\define@key{beamerframe}{bgnone}[true]{\BTKNoBackground}

\newcommand{\BTK@drawbackground}{%
  \ifx\BTK@bgmode\BTK@mode@none
    % nothing
  \else\ifx\BTK@bgmode\BTK@mode@color
    \fill[fill=\BTK@bgcolor,opacity=\BTK@bgopacity]
      (current page.south west) rectangle (current page.north east);%
  \else
    \node[inner sep=0pt,outer sep=0pt,opacity=\BTK@bgopacity] at (current page.center) {%
      \includegraphics[width=\paperwidth,keepaspectratio]{\BTK@bgfile}%
    };%
  \fi\fi
}

% ------------------------------------------------------------
% Per-frame init/reset
% ------------------------------------------------------------
\newif\ifBTK@inited
\BTK@initedfalse

\newcommand{\BTKFrameReset}{%
  \global\BTK@initedfalse
  % clear all boxes
  \BTK@boxclear%
  % Reset background to default for each frame (author can override per frame)
  \BTKUseBackground{\BTK@defaultbg}%
  \BTKSetBackgroundOpacity{1}%
}

%\AtBeginEnvironment{frame}{\BTKFrameReset}
\BeforeBeginEnvironment{frame}{\BTKFrameReset}
%\AfterEndEnvironment{frame}{\BTKFrameReset}  % I don't think this is needed? We reset at the beginning of the frame already?


% ------------------------------------------------------------
% Overlay environment (power mode)
% ------------------------------------------------------------
% This is a nice helper for author code: it creates a TikZ picture with remember picture + overlay, so you can use absolute coordinates and all the anchors defined.
\newenvironment{BTKOverlay}{%
  \begin{tikzpicture}[remember picture,overlay]%
}{%
  \end{tikzpicture}%
}

% ------------------------------------------------------------
% BTK beamer templates
% ------------------------------------------------------------

% Set the background template to draw the current background (which may be set per frame or by theme)
\setbeamertemplate{background}{
  \begin{BTKOverlay}%
    \BTK@drawbackground%
  \end{BTKOverlay}%
}

\makeatother
