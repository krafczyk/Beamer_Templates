% theme/beamerthemencsa.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemencsa}[2026/02/12 NCSA theme on BTK]

\mode<presentation>

\RequirePackage{beamertoolkit}
\RequirePackage{etoolbox}
\usetikzlibrary{calc}
\RequirePackage{fontspec}

% assets live here (theme may append; author adds figs/ separately)
\BTKAppendGraphicPath{theme/assets/}

% Colors
\definecolor{ncsablue}{RGB}{19,31,51}
\definecolor{illiniorange}{RGB}{240,85,55}

% Backgrounds
\BTKDeclareBackground{titleBio}{theme/assets/Title_Bio.jpg}
\BTKDeclareBackground{titleNCSA}{theme/assets/Title_NCSA_Building.jpg}
\BTKDeclareBackground{titleTechA}{theme/assets/Title_Tech_1.jpg}
\BTKDeclareBackground{titleTechB}{theme/assets/Title_Tech_2.jpg}
\BTKDeclareBackground{titleViz}{theme/assets/Title_Viz.jpg}
\BTKDeclareBackground{contentA}{theme/assets/Content_1.jpg}
\BTKDeclareBackground{contentB}{theme/assets/Content_2.jpg}
\BTKUseBackground{contentA} % theme default (author can override per frame)

% Fonts/colors
%\setsansfont{Arial}
%\setmainfont{Arial}
\setsansfont{Montserrat}
\setmainfont{Montserrat}
\setmonofont{Ubuntu Mono}
\setbeamercolor*{title page header}{fg=white}
\setbeamerfont*{title page header}{family=\sffamily,series=\bfseries,size=\Huge}

\setbeamercolor*{frametitle}{fg=ncsablue}
\setbeamerfont*{frametitle}{family=\sffamily,series=\bfseries,size=\fontsize{16}{20}\selectfont}
\setbeamercolor*{framesubtitle}{fg=ncsablue}
\setbeamerfont*{framesubtitle}{family=\sffamily,series=\bfseries,size=\normalsize}

\setbeamercolor*{footline}{fg=white}
\setbeamerfont*{footline}{family=\sffamily,size=\large}

\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor*{normal text}{fg=ncsablue}
\setbeamerfont*{normal text}{family=\sffamily,size=\fontsize{12}{14}\selectfont}
\setbeamertemplate{itemize item}{\raise0.2ex\hbox{\normalsize$\bullet$}}
\setbeamertemplate{itemize subitem}{\raise0.2ex\hbox{\tiny$\bullet$}}
\setbeamercolor*{itemize item}{fg=ncsablue}
\setbeamercolor*{itemize subitem}{fg=ncsablue}
\setbeamertemplate{section in toc}{%
  \leavevmode\usebeamercolor[fg]{section in toc}%
  \hbox{$\vcenter{\hbox{\normalsize$\bullet$}}$}\hspace{0.6em}%
  \inserttocsection\par
}
\setbeamertemplate{subsection in toc}{%
  \leavevmode\usebeamercolor[fg]{subsection in toc}%
  \hspace{1.5em}%
  \hbox{$\vcenter{\hbox{\tiny$\bullet$}}$}\hspace{0.5em}%
  \inserttocsubsection\par
}
\setbeamertemplate{section in toc shaded}{%
  \leavevmode\usebeamercolor[fg]{section in toc shaded}%
  \hbox{$\vcenter{\hbox{\normalsize$\bullet$}}$}\hspace{0.6em}%
  \inserttocsection\par
}
\setbeamertemplate{subsection in toc shaded}{%
  \leavevmode\usebeamercolor[fg]{subsection in toc shaded}%
  \hspace{1.5em}%
  \hbox{$\vcenter{\hbox{\tiny$\bullet$}}$}\hspace{0.5em}%
  \inserttocsubsection\par
}
\setbeamercolor{section in toc shaded}{fg=ncsablue!50}
\setbeamercolor{subsection in toc shaded}{fg=ncsablue!30}
\setbeamercolor{section in toc}{fg=ncsablue}

\setbeamertemplate{navigation symbols}{}

% Install base BTK templates required.
\BTKInstallTemplates

% runs BEFORE beamer parses [key=val,...] for the frame
\BeforeBeginEnvironment{frame}{%
  \BTKUseBackground{contentA}%
  \BTKSetBackgroundOpacity{1}%
  % reset any per-frame BTK state here too
}

\BTKDefineLayout{title}{
  \setbeamertemplate{title page}{
    \begin{BTKOverlay}
      % Title box corners
      \coordinate (NCSA@t@nw) at ($(current page.north)+(0pt,-1.5cm)$);
      \coordinate (NCSA@t@se) at ($(NCSA@t@nw)+(7cm,-3.1cm)$);
      \BTKRectMP[][t][c]{NCSA@t@nw}{NCSA@t@se}{%
        \usebeamercolor[fg]{title page header}%
        \usebeamerfont{title page header}%
        \inserttitle
      }
      % Author/date near bottom
      \coordinate (NCSA@a@nw) at ($(current page.north)+(0cm,-4.6cm)$);
      \coordinate (NCSA@a@se) at ($(NCSA@a@nw)+(7cm, -1cm)$);
      \BTKRectMP[][c][t]{NCSA@a@nw}{NCSA@a@se}{%
        \usebeamercolor[fg]{author}%
        \usebeamerfont{author}%
        \insertauthor
      }
      \coordinate (NCSA@d@se) at ($(current page.south east)+(-0.5cm,0.5cm)$);
      \coordinate (NCSA@d@nw) at ($(NCSA@d@se)+(-4cm,1cm)$);
      \BTKRectMP[][c][c]{NCSA@d@nw}{NCSA@d@se}{%
        \raggedleft
        \usebeamercolor[fg]{date}%
        \usebeamerfont{date}%
        \insertdate
      }
    \end{BTKOverlay}
  }
  \setbeamertemplate{footline}{}
  \setbeamertemplate{frametitle}{}
  \setbeamertemplate{btk overlay}{}
}

\newcommand{\NCSA@footframe}{%
  \setbeamertemplate{footline}{%
    \begin{BTKOverlay}
      % slide numbers box
      \coordinate (NCSA@footnumber@nw) at ($(current page.south)+(-1cm,0.7cm)$);
      \coordinate (NCSA@footnumber@se) at ($(current page.south)+(1cm,0cm)$);
      \BTKRectMP[fill=none][c][c]{NCSA@footnumber@nw}{NCSA@footnumber@se}{%
        \centering
        \usebeamercolor[fg]{footline}\usebeamerfont{footline}\insertframenumber/\insertmainframenumber
      }
    \end{BTKOverlay}
  }
}

\newcommand{\NCSA@topbar}[1]{%
  % Title box corners
  \coordinate (b1) at ($(current page.north west)+(0cm,-4pt)$);
  \coordinate (b2) at ($(current page.north east)+(0cm,-1cm)$);
  \path[fill=ncsagrey] (b1) rectangle (b2);
  \coordinate (NCSA@t@nw) at ($(current page.north west)+(3pt,-4pt)$);
  \coordinate (NCSA@t@se) at ($(current page.north east)+(-3pt,-1cm)$);
  \BTKRectMP[fill=none][c][c]{NCSA@t@nw}{NCSA@t@se}{%
    #1
  }
}

\newcommand{\NCSA@frame}{%
  \setbeamertemplate{title page}{}
  \NCSA@footframe
  \setbeamertemplate{frametitle}{%
    \begin{BTKOverlay}
      \NCSA@topbar{
        \usebeamercolor[fg]{frametitle}%
        \usebeamerfont{frametitle}%
        \insertframetitle
      }
    \end{BTKOverlay}
  }
  \setbeamertemplate{framesubtitle}{}
}

\BTKDefineLayout{full}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    % Main text box
    \coordinate (NCSA@t1@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,1.0cm)$);
    %\coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,0.7cm)$);
    \BTKSetBoxPaddingFromBeamerFont{normal text}
    \BTKRectMP[fill=none][c][t]{NCSA@t1@nw}{NCSA@t1@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{text}%
    }
  }
}

\BTKDefineLayout{two-col}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    % Left text box
    \coordinate (NCSA@l@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@l@se) at ($(current page.south)+(-2pt,1.0cm)$);
    \BTKSetBoxPaddingFromBeamerFont{normal text}
    \BTKRectMP[fill=none][c][t]{NCSA@l@nw}{NCSA@l@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{left}%
    }
    % Right text box
    \coordinate (NCSA@r@nw) at ($(current page.north)+(2pt,-1.07cm)$);
    \coordinate (NCSA@r@se) at ($(current page.south east)+(-2pt,1.0cm)$);
    \BTKRectMP[fill=none][c][t]{NCSA@r@nw}{NCSA@r@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{right}%
    }
  }
}

\BTKDefineLayout{img-right}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    \coordinate (NCSA@t1@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,1.0cm)$);

    \BTKSetBoxPaddingFromBeamerFont{normal text}

    % defaults if author didn't set them
    \def\BTK@imgw{\BTKGetOptionOr{img-width}{0.34\linewidth}}
    \def\BTK@imgside{\BTKGetOptionOr{img-side}{r}}
    \def\BTK@imgvspace{\BTKGetOptionOr{img-vspace}{-0.5\baselineskip}}
    \def\BTK@imggap{\BTKGetOptionOr{img-gap}{0.6em}}

    \BTKRectMP[fill=none][c][t]{NCSA@t1@nw}{NCSA@t1@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%

      % wrapfig uses \columnsep for the text-image gap
      \setlength{\columnsep}{\BTK@imggap}%

      \begin{wrapfigure}{\BTK@imgside}{\BTK@imgw}
        \vspace{\BTK@imgvspace}%
        \centering
        \BTKGetContent{img}%
      \end{wrapfigure}

      \BTKGetContent{text}%
    }
  }
}

% Title slide convenience wrapper (forces BTK frame keys)
\newcommand{\TitleFrame}{%
  \begin{frame}[plain,noframenumbering,bg=titleTechA,layout=title]
    \titlepage
  \end{frame}
}

% Toggle section/subsection slides
\newif\ifBTKSectionSlides
\BTKSectionSlidestrue
\newif\ifBTKSubsectionSlides
\BTKSubsectionSlidesfalse  % default off (usually noisy)

% A clean “section slide” layout (no header/footer)
\BTKDefineLayout{section-slide}{
  \setbeamertemplate{title page}{}
  \NCSA@footframe
  \setbeamertemplate{frametitle}{}
  \setbeamertemplate{framesubtitle}{}
  \setbeamertemplate{btk overlay}{
    \NCSA@topbar{
      \usebeamercolor[fg]{frametitle}%
      \usebeamerfont{frametitle}%
      \BTKGetContent{section-title}
    }
    % Main text box
    \coordinate (NCSA@t1@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,1.0cm)$);
    \BTKSetBoxPaddingFromBeamerFont{normal text}
    \BTKRectMP[fill=none][c][t]{NCSA@t1@nw}{NCSA@t1@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{section-body}
    }
  }
}

% Appendix announce layout (no header/footer, appendix background)
\BTKDefineLayout{appendix-announce}{
  \BTKUseBackground{appendix}%
  \setbeamertemplate{title page}{}%
  \setbeamertemplate{footline}{}%
  \setbeamertemplate{frametitle}{}%
  \setbeamertemplate{btk overlay}{%
    % Title box corners
    \coordinate (NCSA@t@nw) at ($(current page.north west)+(0.3pt,-0.4cm)$);
    \coordinate (NCSA@t@se) at ($(current page.north east)+(-0.3pt,-5.7cm)$);
    \BTKRectMP[][c][c]{NCSA@t@nw}{NCSA@t@se}{%
      \centering
      \usebeamercolor[fg]{title page header}%
      \usebeamerfont{title page header}%
      \BTKGetContent{appendix-title}
    }
  }%
}

\AtBeginSection[]{
  \ifBTKSectionSlides
    \begin{frame}[plain,noframenumbering,layout=section-slide,bg=contentA]
      \BTKContent{section-title}{\insertsectionhead}
      \BTKContent{section-body}{\tableofcontents[currentsection,hideothersubsections]}
    \end{frame}
  \fi
}

\AtBeginSubsection[]{
  \ifBTKSubsectionSlides
    \begin{frame}[plain,noframenumbering,layout=section-slide,bg=contentA]
      \BTKContent{section-title}{\insertsubsectionhead}
      \BTKContent{section-body}{}
    \end{frame}
  \fi
}

\newcommand{\AppendixAnnounce}[1]{%
  \BTKAppendixBegin
  \begin{frame}[plain,noframenumbering,layout=appendix-announce]
    \BTKContent{appendix-title}{#1}
  \end{frame}
}

\mode<all>
