% theme/beamerthemencsa.sty
\mode<presentation>

\RequirePackage{beamertoolkit}
\RequirePackage{tikz}
\RequirePackage{graphicx}

% Adjust these to match your header/footer visuals
\setlength{\BTKHeaderH}{1.05cm}
\setlength{\BTKFooterH}{0.75cm}
\setlength{\BTKGutter}{0.9cm}
\setlength{\BTKImgW}{0.36\paperwidth}

% Colors (example)
\definecolor{ncsagrey}{RGB}{102,102,102}
\definecolor{ncsablue}{RGB}{0,81,174}

% Declare background set
\BTKDeclareBackground{default}{theme/assets/ncsa_generic_slide_background.jpg}
\BTKDeclareBackground{title}{theme/assets/ncsa_title_background.jpg}
\BTKDeclareBackground{appendix}{theme/assets/ncsa_title_background.jpg}

% Optional alternates (add files if you want)
% \BTKDeclareBackground{dark}{theme/assets/bg_dark.png}
% \BTKDeclareBackground{grid}{theme/assets/bg_grid.png}

\BTKSetDefaultBackground{default}
\BTKSetTitleBackground{title}
\BTKSetAppendixBackground{appendix}
\BTKSetDefaultLayout{full}

% Framestyle: top bar
\setbeamercolor{frametitle}{fg=white}
\setbeamercolor{framesubtitle}{fg=white}
\setbeamerfont{frametitle}{size=\Large}
\setbeamerfont{framesubtitle}{size=\normalsize}

\defbeamertemplate*{frametitle}{ncsa}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[ncsagrey]
      (\BTKHeaderAnchor{sw}) rectangle (\BTKHeaderAnchor{ne});
    \node[anchor=west,inner sep=0pt,outer sep=0pt]
      at ($(\BTKHeaderAnchor{sw})+(0.6cm,0.35cm)$) {%
        \usebeamerfont{frametitle}\insertframetitle%
        \ifx\insertframesubtitle\empty\else\ \usebeamerfont{framesubtitle}\insertframesubtitle\fi
      };
  \end{tikzpicture}%
  \vspace*{0.65cm}%
}
\setbeamertemplate{frametitle}[ncsa]

% Footline with main/appendix counting
\setbeamercolor{footline}{fg=white}
\setbeamerfont{footline}{size=\normalsize}

\setbeamertemplate{footline}{%
  \ifnum\value{framenumber}>0\relax
    \begin{tikzpicture}[remember picture,overlay]
      \node[anchor=south,inner sep=0pt,outer sep=0pt]
        at ($(\BTKFooterAnchor{c})+(0cm,0.10cm)$) {%
          \usebeamerfont{footline}\insertframenumber/\insertmainframenumber%
        };
    \end{tikzpicture}%
  \fi
}

\setbeamertemplate{navigation symbols}{}

% Backup convenience
\newcommand{\backupbegin}{\appendix}

\mode<all>
