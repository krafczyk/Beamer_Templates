\mode<presentation>

% Requirement
\RequirePackage{tikz}
%\RequirePackage{calc}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}
%\RequirePackage{scrextend}
%\RequirePackage[absolute,overlay]{textpos}
\usetikzlibrary{positioning}
\usetikzlibrary{calc}
\usetikzlibrary{matrix}
\usetikzlibrary{babel}

\graphicspath{{theme/assets/}}

% Fallback for older beamer versions
\providecommand{\insertmainframenumber}{\inserttotalframenumber}

% Backup state flags (theme-global)
\newif\ifbackupslides
\backupslidesfalse

\newif\ifbackupannounce
\backupannouncefalse

% User-facing commands
\newcommand{\backupbegin}{%
  \appendix
  \backupslidestrue
}

\newcommand{\backupend}{%
  \backupslidesfalse
}

% a single “Backup Slides” separator frame, styled by your background template
\newcommand{\backupannounceslide}{%
  {%
    \backupannouncetrue
    \begin{frame}[plain,noframenumbering]
      \vfill
      \centering
      \usebeamerfont{title page header}Backup Slides
      \vfill
    \end{frame}
  }%
}

\definecolor{ncsablue}{RGB}{0,81,174}
\definecolor{ncsagrey}{RGB}{102,102,102}

% Settings

%\useinnertheme{ncsa}
\useoutertheme{ncsa}
\usecolortheme{ncsa}

\addtolength{\headsep}{0.4cm}

\setbeamersize{text margin left=0.3cm,text margin right=0.3cm}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[rounded][shadow=true]

\mode<all>
