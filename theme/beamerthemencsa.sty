\mode<presentation>

% Requirement
\RequirePackage{tikz}
%\RequirePackage{calc}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}
\RequirePackage{ifthen}
%\RequirePackage{scrextend}
%\RequirePackage[absolute,overlay]{textpos}
\usetikzlibrary{positioning}
\usetikzlibrary{calc}
\usetikzlibrary{matrix}
