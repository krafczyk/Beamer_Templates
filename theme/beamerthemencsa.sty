% theme/beamerthemencsa.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemencsa}[2026/02/12 NCSA theme on BTK]

\mode<presentation>

\RequirePackage{beamertoolkit}
\RequirePackage{etoolbox}
\usetikzlibrary{calc}
\RequirePackage{fontspec}

% assets live here (theme may append; author adds figs/ separately)
\BTKAppendGraphicPath{theme/assets/}

% Colors
\definecolor{ncsablue}{RGB}{0,81,174}
\definecolor{ncsagrey}{RGB}{102,102,102}

% Geometry knobs owned by theme
\newlength{\NCSAHeaderH}
\newlength{\NCSAFooterH}
\newlength{\NCSAGutter}
\newlength{\NCSAImgW}
\setlength{\NCSAHeaderH}{1.05cm}
\setlength{\NCSAFooterH}{0.75cm}
\setlength{\NCSAGutter}{0.9cm}
\setlength{\NCSAImgW}{0.36\paperwidth}

% Backgrounds
\BTKDeclareBackground{default}{theme/assets/ncsa_generic_slide_background.jpg}
\BTKDeclareBackground{title}{theme/assets/ncsa_title_background.jpg}
\BTKDeclareBackground{appendix}{theme/assets/ncsa_title_background.jpg}
\BTKUseBackground{default} % theme default (author can override per frame)

% Fonts/colors
%\setsansfont{Arial}
%\setmainfont{Arial}
\setsansfont{Liberation Sans}
\setmainfont{Liberation Sans}
\setmonofont{Ubuntu Mono}
\setbeamercolor*{title page header}{fg=white}
\setbeamerfont*{title page header}{family=\sffamily,series=\bfseries,size=\Huge}

\setbeamercolor*{frametitle}{fg=white}
\setbeamerfont*{frametitle}{family=\sffamily,series=\bfseries,size=\fontsize{16}{20}\selectfont}
\setbeamercolor*{framesubtitle}{fg=white}
\setbeamerfont*{framesubtitle}{family=\sffamily,series=\bfseries,size=\normalsize}

\setbeamercolor*{footline}{fg=white}
\setbeamerfont*{footline}{family=\sffamily,size=\large}

\setbeamercolor*{author}{fg=ncsagrey}
\setbeamercolor*{date}{fg=ncsagrey}
\setbeamercolor*{normal text}{fg=ncsagrey}
\setbeamerfont*{normal text}{family=\sffamily,size=\fontsize{12}{14}\selectfont}
\setbeamertemplate{itemize item}{\raise0.2ex\hbox{\normalsize$\bullet$}}
\setbeamertemplate{itemize subitem}{\raise0.2ex\hbox{\tiny$\bullet$}}
\setbeamercolor*{itemize item}{fg=ncsagrey}
\setbeamercolor*{itemize subitem}{fg=ncsagrey}

\setbeamertemplate{navigation symbols}{}

% Install base BTK templates required.
\BTKInstallTemplates

% runs BEFORE beamer parses [key=val,...] for the frame
\BeforeBeginEnvironment{frame}{%
  \BTKUseBackground{default}%
  \BTKSetBackgroundOpacity{1}%
  % reset any per-frame BTK state here too
}

\BTKDefineLayout{title}{
  \BTKUseBackground{title}%
  \setbeamertemplate{title page}{
    \begin{BTKOverlay}
      % Title box corners
      \coordinate (NCSA@t@nw) at ($(current page.north west)+(0.3pt,-0.4cm)$);
      \coordinate (NCSA@t@se) at ($(current page.north east)+(-0.3pt,-5.7cm)$);
      \BTKRectMP[][c][c]{NCSA@t@nw}{NCSA@t@se}{%
        \centering
        \usebeamercolor[fg]{title page header}%
        \usebeamerfont{title page header}%
        \inserttitle
      }
      % Author/date near bottom
      \coordinate (NCSA@a@nw) at ($(current page.south west)+(0.1cm,3.05cm)$);
      \coordinate (NCSA@a@se) at ($(current page.south west)+(12cm,2.00cm)$);
      \BTKRectMP[][c][c]{NCSA@a@nw}{NCSA@a@se}{%
        \usebeamerfont{author}\insertauthor
      }
      \coordinate (NCSA@d@nw) at ($(current page.south east)+(-4cm,3.05cm)$);
      \coordinate (NCSA@d@se) at ($(current page.south east)+(-0.1cm,2.00cm)$);
      \BTKRectMP[][c][c]{NCSA@d@nw}{NCSA@d@se}{%
        \raggedleft
        \usebeamerfont{date}\insertdate
      }
    \end{BTKOverlay}
  }
  \setbeamertemplate{footline}{}
  \setbeamertemplate{frametitle}{}
  \setbeamertemplate{btk overlay}{}
}

\newcommand{\NCSA@frame}{%
  \setbeamertemplate{title page}{}
  \setbeamertemplate{footline}{%
    \begin{BTKOverlay}
      % slide numbers box
      \coordinate (NCSA@footnumber@nw) at ($(current page.south)+(-1cm,0.7cm)$);
      \coordinate (NCSA@footnumber@se) at ($(current page.south)+(1cm,0cm)$);
      \BTKRectMP[fill=none][c][c]{NCSA@footnumber@nw}{NCSA@footnumber@se}{%
        \centering
        \usebeamercolor[fg]{footline}\usebeamerfont{footline}\insertframenumber/\insertmainframenumber
      }
    \end{BTKOverlay}
  }
  \setbeamertemplate{frametitle}{%
    \begin{BTKOverlay}
      % Title box corners
      \coordinate (b1) at ($(current page.north west)+(0cm,-4pt)$);
      \coordinate (b2) at ($(current page.north east)+(0cm,-1cm)$);
      \path[fill=ncsagrey] (b1) rectangle (b2);
      \coordinate (NCSA@t@nw) at ($(current page.north west)+(3pt,-4pt)$);
      \coordinate (NCSA@t@se) at ($(current page.north east)+(-3pt,-1cm)$);
      \BTKRectMP[fill=none][c][c]{NCSA@t@nw}{NCSA@t@se}{%
        \usebeamercolor[fg]{frametitle}%
        \usebeamerfont{frametitle}%
        \insertframetitle
      }
    \end{BTKOverlay}
  }
  \setbeamertemplate{framesubtitle}{}
}

\BTKDefineLayout{full}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    % Main text box
    \coordinate (NCSA@t1@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,1.0cm)$);
    %\coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,0.7cm)$);
    \BTKSetBoxPaddingFromBeamerFont{normal text}
    \BTKRectMP[fill=none][c][t]{NCSA@t1@nw}{NCSA@t1@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{text}%
    }
  }
}

\BTKDefineLayout{two-col}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    % Left text box
    \coordinate (NCSA@l@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@l@se) at ($(current page.south)+(-2pt,1.0cm)$);
    \BTKSetBoxPaddingFromBeamerFont{normal text}
    \BTKRectMP[fill=none][c][t]{NCSA@l@nw}{NCSA@l@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{left}%
    }
    % Right text box
    \coordinate (NCSA@r@nw) at ($(current page.north)+(2pt,-1.07cm)$);
    \coordinate (NCSA@r@se) at ($(current page.south east)+(-2pt,1.0cm)$);
    \BTKRectMP[fill=none][c][t]{NCSA@r@nw}{NCSA@r@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%
      \BTKGetContent{right}%
    }
  }
}

\BTKDefineLayout{img-right}{
  \NCSA@frame
  \setbeamertemplate{btk overlay}{
    \coordinate (NCSA@t1@nw) at ($(current page.north west)+(2pt,-1.07cm)$);
    \coordinate (NCSA@t1@se) at ($(current page.south east)+(-2pt,1.0cm)$);

    \BTKSetBoxPaddingFromBeamerFont{normal text}

    % defaults if author didn't set them
    \def\BTK@imgw{\BTKGetOptionOr{img-width}{0.34\linewidth}}
    \def\BTK@imgside{\BTKGetOptionOr{img-side}{r}}
    \def\BTK@imgvspace{\BTKGetOptionOr{img-vspace}{-0.5\baselineskip}}
    \def\BTK@imggap{\BTKGetOptionOr{img-gap}{0.6em}}

    \BTKRectMP[fill=none][c][t]{NCSA@t1@nw}{NCSA@t1@se}{%
      \usebeamercolor[fg]{normal text}%
      \usebeamerfont{normal text}%

      % wrapfig uses \columnsep for the text-image gap
      \setlength{\columnsep}{\BTK@imggap}%

      \begin{wrapfigure}{\BTK@imgside}{\BTK@imgw}
        \vspace{\BTK@imgvspace}%
        \centering
        \BTKGetContent{img}%
      \end{wrapfigure}

      \BTKGetContent{text}%
    }
  }
}

% Title slide convenience wrapper (forces BTK frame keys)
\newcommand{\TitleFrame}{%
  \begin{frame}[plain,noframenumbering,bg=title,layout=title]
    \titlepage
  \end{frame}
}

