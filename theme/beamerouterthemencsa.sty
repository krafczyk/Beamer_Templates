\mode<presentation>

% Frame title 
\defbeamertemplate*{frametitle}{ncsa}[1][] {
	\begin{tikzpicture}[remember picture,overlay]
		\node[below right,inner sep=0pt,outer sep=0pt,fill=ncsagrey,minimum width=\paperwidth,minimum height=0.9cm] (titlebox) at ($(current page.north west)+(0cm,-0.135cm)$) {};
		\node[right,inner sep=0pt,outer sep=0pt] (title) at ($(titlebox.west)+(0.6cm,0cm)$) {
			\usebeamerfont{frametitle}\insertframetitle\ifx\insertframesubtitle\empty\else : \fi
		};
		\node[right,inner sep=0pt,outer sep=0pt] at ($(title.east)+(0.6cm,0cm)$) {
			\usebeamerfont{framesubtitle}\insertframesubtitle
		};
	\end{tikzpicture}
}

% Footline
\setbeamertemplate{footline} {
  % Hide on title and on the backup announce slide
  \ifbackupannounce\relax\else
    \ifnum\value{framenumber}>1\relax
      \begin{tikzpicture}[remember picture,overlay]
        \node[right] at ($(current page.south west)+(0.7cm,0.35cm)$) {
          \includegraphics[width=2.5cm,keepaspectratio]{illinois_banner.png}
        };
        \node[above] at ($(current page.south)+(0cm,0.1cm)$) {
          \usebeamerfont{footline}\insertframenumber/\insertmainframenumber
        };
      \end{tikzpicture}
    \fi
  \fi
}

\mode<all>
