\mode<presentation>

% Pick background image file
\newcommand*{\ncsabackgroundfile}{%
  \ifbackupannounce%
    ncsa_title_background.jpg%
  \else%
    \ifnum\value{framenumber}=1\relax%
      ncsa_title_background.jpg%
    \else%
      ncsa_generic_slide_background.jpg%
    \fi%
  \fi%
}

\newcommand{\ncsaoptcomma}[1]{%
  \ifx\relax#1\relax\else,#1\fi%
}

\setbeamertemplate{background}{%
  \begin{tikzpicture}[remember picture,overlay]
    \node[inner sep=0pt,outer sep=0pt] at (current page.center) {%
      \includegraphics[width=\paperwidth,keepaspectratio]{\ncsabackgroundfile}%
    };
  \end{tikzpicture}%
}

% Title page
\defbeamertemplate{title page}{ncsa}[1][]{%
  \begin{tikzpicture}[remember picture,overlay]
    \node at ($(current page.center)+(0cm,1.8cm)$) {%
      \begin{beamercolorbox}[
        wd=12cm%
        \ncsaoptcomma{#1}%
      ]{title page header}
        \begin{center}
          \usebeamerfont{title page header}\inserttitle
        \end{center}
      \end{beamercolorbox}
    };
    \node[inner sep=0pt,outer sep=0pt,right] at ($(current page.south west)+(0.5cm,2.5cm)$) {%
      \begin{minipage}{7cm}
        \begin{beamercolorbox}[
          wd=7cm%
          \ncsaoptcomma{#1}%
        ]{author}
          \usebeamerfont{author}\insertauthor
        \end{beamercolorbox}
      \end{minipage}
    };
    \node[inner sep=0pt,outer sep=0pt,left] at ($(current page.south east)+(-0.5cm,2.5cm)$) {%
      \begin{minipage}{4cm}
        \begin{beamercolorbox}[
          wd=4cm%
          \ncsaoptcomma{#1}%
        ]{date}
          \raggedleft
          \usebeamerfont{date}\insertdate
        \end{beamercolorbox}
      \end{minipage}
    };
  \end{tikzpicture}%
}
\setbeamertemplate{title page}[ncsa]

\mode<all>
